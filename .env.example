# veradis-copilot — environment reference (E-F). Copy to .env.local; never
# commit real values. Every adapter runs as a stub when its key is absent and
# logs `STUBBED: <adapter>` — the app works with an empty env.

# ── Copilot Supabase (project veradis-copilot, ref lpfmaaeuojextcqhsivs) ─────
# Flips the data layer to SupabaseRepository + Supabase Storage.
# Requires migrations 0001 (applied) + 0002 (Studio SQL editor).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Evidence bucket (default verify-uploads)
SUPABASE_STORAGE_BUCKET=
# Force the in-memory data layer even with creds present (local dev / tests)
DATA_BACKEND=

# ── Claude (vision + narrative; one Anthropic key covers both) ───────────────
ANTHROPIC_API_KEY=
# Optional per-adapter overrides
VISION_API_KEY=
VISION_MODEL=
NARRATIVE_API_KEY=
NARRATIVE_MODEL=

# ── veradis-accounts bridge (verify.veradis.ai account store) ────────────────
# Photo download (intake) + report write-back (delivery). ONE direction only:
# the bridge only writes to its `reports` rows. Never operating-prod tables.
VERADIS_ACCOUNTS_URL=
VERADIS_ACCOUNTS_SERVICE_ROLE_KEY=
# Shared secret for POST /api/intake/veradis (also set in verify-store env)
VERADIS_INTAKE_SIGNING_SECRET=

# ── Tally intake ─────────────────────────────────────────────────────────────
TALLY_SIGNING_SECRET=

# ── Tier-1 sources / other adapters (Phase A stubs until keys land) ──────────
PCGS_API_TOKEN=
NUMISTA_API_KEY=
EMBEDDINGS_API_KEY=
TRADEGOV_CSL_KEY=

# ── Email (Resend) + links ───────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
CURATOR_EMAIL=
PUBLIC_BASE_URL=
